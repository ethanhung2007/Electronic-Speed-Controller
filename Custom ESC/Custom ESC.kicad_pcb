	(layers
		(0 "F.Cu" signal)
		(4 "In1.Cu" power)
		(6 "In2.Cu" power)
		(2 "B.Cu" signal)
		(9 "F.Adhes" user "F.Adhesive")
		(11 "B.Adhes" user "B.Adhesive")
